# storybot.env -- copy to storybot.env, fill in, chmod 600.
# Loaded ONLY via systemd EnvironmentFile (cron/systemd never read ~/.bashrc).
# ANTHROPIC_API_KEY is NOT here -- the unit also loads
# /mnt/hermes/profiles/plug/.env which already carries it.

# --- required ---------------------------------------------------------------
# Discord application "story bot" -> Bot -> Token (no privileged intents).
STORY_DISCORD_TOKEN=

# Free instant key: https://www.pexels.com/api/
PEXELS_API_KEY=

# --- strongly recommended -----------------------------------------------------
# ElevenLabs Creator plan key (https://elevenlabs.io -> Profile -> API keys).
# Leave empty to fall back to free edge-tts voices (works, sounds worse,
# fine for testing the pipeline end to end).
ELEVENLABS_API_KEY=

# --- optional ----------------------------------------------------------------
# Second stock source, free key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# STORY_GUILD_ID=1508706852035231815      # the bot! server (default)
# STORY_CATEGORY_NAME=Story Pipeline
# STORY_FEED_CHANNEL=story-feed
# STORY_QUEUE_CHANNEL=story-queue
# STORY_BOT_NAME=SCOUT
# STORY_WORKSPACE=OBSCURA

# STORY_MODEL=claude-sonnet-5             # generator/judge/shot-writer
# STORY_MODEL_FAST=claude-haiku-4-5       # keyword rewrites, salvage parses
# STORY_MAX_SEARCHES=6                    # web searches per generator call

# STORY_THRESHOLD=4.0                     # RECOMMENDED cutoff (stars)
# STORY_DAILY=1                           # daily auto-generation on/off
# STORY_DAILY_TARGET=12                   # drafts/day (spread across the day)
# STORY_GEN_BATCH=3                       # per-batch size + Generate default
# STORY_MAX_GEN=10                        # per-click ceiling in the web console
# STORY_WEB_AUTOGEN=1                     # standalone console: auto-generate (0=off)
# STORY_MAX_RENDERS_PER_DAY=5

# --- Costs tab: estimated API pricing (USD; override if rates change) ---
# STORY_PRICE_IN_MAIN=2.00                # sonnet-5 input $/1M (intro; 3.00 after 2026-08-31)
# STORY_PRICE_OUT_MAIN=10.00              # sonnet-5 output $/1M (intro; 15.00 after)
# STORY_PRICE_IN_FAST=1.00                # haiku-4.5 input $/1M
# STORY_PRICE_OUT_FAST=5.00               # haiku-4.5 output $/1M
# STORY_PRICE_WEBSEARCH=10.00             # web search $ per 1,000

# STORY_TTS_MODEL=eleven_multilingual_v2
# STORY_TTS_FORMAT=mp3_44100_128          # Creator can use mp3_44100_192
# STORY_VOICE_DEFAULT=                    # force one ElevenLabs voice id
# STORY_VOICE_MYSTERIOUS=                 # ...or override per tone key:
# STORY_VOICE_CINEMATIC=                  #   mysterious cinematic dark
# STORY_VOICE_DARK=                       #   suspense documentary
# STORY_VOICE_SUSPENSE=
# STORY_VOICE_DOCUMENTARY=
# STORY_EDGE_VOICE=                       # force one edge-tts voice

# --- web console (OBSCURA UI) -------------------------------------------------
# Served by the bot process itself (and standalone via `python web.py`).
# STORY_WEB=1                             # 0 disables the web console
# STORY_WEB_HOST=127.0.0.1                # keep loopback; expose via cloudflared
# STORY_WEB_PORT=8377
# STORY_WEB_SECRET=                       # optional: require /?key=<secret>

# STORY_XFADE=0.2                         # crossfade seconds
# STORY_FFMPEG_THREADS=3                  # be polite on the 6-core box
# STORY_CAPTION_FONT=Liberation Sans
# STORY_CAPTION_UPPER=1
# STORY_PEXELS_HOURLY=190                 # stay under the 200/hr limit
